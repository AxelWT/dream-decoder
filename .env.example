# ACR 镜像地址
ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ACR_NAMESPACE=your-namespace

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password
POSTGRES_DB=dream_decoder

# Backend 环境变量
DATABASE_URL=postgresql://postgres:your-strong-password@postgres:5432/dream_decoder?schema=public
JWT_SECRET=your-super-secret-jwt-key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# SMTP 邮件
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Dream Decoder <your-email@qq.com>

# PayJS 支付
PAYJS_KEY=your-payjs-key
PAYJS_MCHID=your-merchant-id

# URL 配置
FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://your-domain.com

# 服务端口
PORT=3001

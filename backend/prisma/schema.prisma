generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  passwordHash    String?
  nickname        String?
  avatar          String?
  credits         Int            @default(10)
  plan            String         @default("FREE")
  lastDailyBonus  DateTime?
  createdAt       DateTime       @default(now())
  profile         Profile?
  subscription    Subscription?
  orders          Order[]
  dreams          Dream[]
  chatSessions    ChatSession[]
  cards           DreamCard[]
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  ageRange        String?
  gender          String?
  occupation      String?
  stressLevel     Int?
  concerns        String[]
  lifeChanges     String[]
  mbti            String?
  dreamFrequency  String?
  lucidDreamExp   Boolean  @default(false)
  psychKnowledge  String?
  preferredSchool String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Dream {
  id           String        @id @default(cuid())
  userId       String
  title        String?
  content      String
  emotions     String[]
  clarity      String?
  dreamType    String?
  scenes       String[]
  aiSummary    String?
  anxietyScore Float?
  recordedAt   DateTime      @default(now())
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions     ChatSession[]
  cards        DreamCard[]

  @@index([userId, recordedAt])
}

model ChatSession {
  id        String    @id @default(cuid())
  userId    String
  dreamId   String?
  school    String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dream     Dream?    @relation(fields: [dreamId], references: [id], onDelete: SetNull)
  messages  Message[]

  @@index([userId, createdAt])
}

model Message {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model DreamCard {
  id           String   @id @default(cuid())
  userId       String
  dreamId      String
  style        String   // "mystic", "watercolor", "minimal", "surreal"
  title        String?
  symbols      String[]
  theme        String?
  quote        String?
  school       String?
  emotions     String[]
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dream        Dream    @relation(fields: [dreamId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  plan             String    // PRO | PREMIUM | LIFETIME
  status           String    // active | canceled | expired
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id           String   @id @default(cuid())
  userId       String
  plan         String   // PRO | PREMIUM | LIFETIME
  amount       Int      // 价格（分）
  orderId      String   @unique // PayJS 订单号
  payjsOrderId String?  // PayJS 返回的 orderid
  status       String   @default("pending") // pending | paid | failed
  createdAt    DateTime @default(now())
  paidAt       DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

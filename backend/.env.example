# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dream_decoder?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# DeepSeek API
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"

# Email (SMTP)
SMTP_HOST="smtp.qq.com"
SMTP_PORT="465"
SMTP_USER="your-email@qq.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Dream Decoder <your-email@qq.com>"

# Stripe
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
STRIPE_PRO_PRICE_ID="price_your-pro-price-id"
STRIPE_PREMIUM_PRICE_ID="price_your-premium-price-id"

# Frontend URL (for Stripe redirects)
FRONTEND_URL="http://localhost:5173"

# Server
PORT=3001
